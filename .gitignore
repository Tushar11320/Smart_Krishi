# -------------------------------------------------------------------------
# 1. Environment & Secrets Files (Strictly Ignored)
# -------------------------------------------------------------------------
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Subdirectory env configurations
**/frontend/.env*
**/backend/.env*

# Spring Boot Configuration Secrets & Local Settings
**/application-local.yml
**/application-dev.yml
**/application-secrets.yml
**/application-prod.yml
**/application-local.properties
**/application-dev.properties
**/application-secrets.properties

# Secrets, keys and credentials folders
secrets/
keys/
credentials/
certs/
*.pem
*.key
*.p12
*.jks

# -------------------------------------------------------------------------
# 2. Build & Target Artifacts
# -------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
target/
out/
bin/
obj/
maven/

# Maven build files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.restore
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

